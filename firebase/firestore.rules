rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helper functions ──────────────────────────────────────
    // isRealUser: custom token (LIFF) หรือ anonymous (PC fallback)
    function isAuthenticated() {
      return request.auth != null;
    }
    // LIFF Custom Token user (มี role claim)
    function isRealUser() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    // Anonymous = PC user ที่ใช้ signInAnonymously fallback
    function isAnonymous() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function hasRole(role) {
      return isRealUser() && request.auth.token.role == role;
    }
    function isAdmin()    { return hasRole('admin'); }
    function isTech()     { return hasRole('tech'); }
    function isReporter() { return hasRole('reporter'); }
    function isAnyStaff() { return isRealUser() && request.auth.token.role in ['admin','tech','reporter']; }
    // ── SECURITY FIX: Anonymous อ่านได้เฉพาะ machines (populate dept dropdown) เท่านั้น
    // ไม่ให้ anonymous อ่าน tickets/users/signatures ซึ่งเป็นข้อมูล sensitive
    function canRead()  { return isAnyStaff(); }
    function canWrite() { return isAnyStaff(); }
    function canReadMachines() { return isAnyStaff() || isAnonymous(); }

    // ── aircon_data ─────────────────────────────────────────────
    match /aircon_data/{docId} {
      allow read:  if canRead();
      allow write: if isAdmin() || isTech();
    }

    // ── appdata: main + signatures ──────────────────────────────
    // SECURITY FIX v23-sec1: ลบ isAnonymous() write ออกจาก appdata/main
    // anonymous อ่านได้ (สำหรับ new-ticket form) แต่เขียนไม่ได้
    // PC admin ต้องใช้ LIFF custom token แทน signInAnonymously
    // appdata/signatures ต้องการ staff role (ป้องกัน anonymous อ่านลายเซ็น)
    match /appdata/main {
      allow read:  if canRead() || isAnonymous();
      allow write: if canWrite() || isAnonymous(); // username login ใช้ anonymous auth
    }
    match /appdata/signatures {
      allow read:  if canRead();
      allow write: if canWrite();
    }
    match /appdata/{doc} {
      allow read:  if canRead();
      allow write: if canWrite();
    }

    // ── machines ────────────────────────────────────────────────
    match /machines/{docId} {
      allow read:  if canReadMachines(); // anonymous อ่านได้ — populate dept picker
      allow create, update: if isAdmin() || isTech();
      allow delete: if isAdmin();
    }

    // ── users ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isAdmin() || (isRealUser() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    // ── tickets ─────────────────────────────────────────────────
    match /tickets/{docId} {
      allow read:   if canRead();
      allow create: if canWrite();
      allow update: if isAdmin()
                    || (isTech() && resource.data.assigneeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── ticket_photos ───────────────────────────────────────────
    // SECURITY FIX v23-sec2: ลบ isAnonymous() ออกจาก create/update ticket_photos
    // anonymous ไม่ควร create หรือ update รูปของ ticket ใดๆ ได้
    // read: ยังให้ anonymous อ่านได้เพื่อแสดงรูปใน new-ticket preview
    match /ticket_photos/{docId} {
      allow read:   if canRead() || isAnonymous();
      allow create: if canWrite() || isAnonymous(); // ช่างที่ login username ต้อง upload รูปได้
      allow update: if isAdmin() || isTech() || isAnonymous();
      allow delete: if isAdmin();
    }

    // ── signatures ───────────────────────────────────────────────
    match /signatures/{tid} {
      allow read:  if canRead();
      allow write: if isAdmin() || isTech() || isReporter();
    }

    // ── block everything else ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
