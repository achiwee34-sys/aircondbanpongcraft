rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── F-02: helper functions ──────────────────────────────────
    // บล็อก Anonymous auth — ต้องเป็น real user เท่านั้น
    function isRealUser() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // F-05: role จาก Firebase Custom Claims
    function hasRole(role) {
      return isRealUser() && request.auth.token.role == role;
    }
    function isAdmin()    { return hasRole('admin'); }
    function isTech()     { return hasRole('tech'); }
    function isReporter() { return hasRole('reporter'); }
    function isAnyStaff() { return isRealUser() && request.auth.token.role in ['admin','tech','reporter']; }

    // ── aircon_data ─────────────────────────────────────────────
    match /aircon_data/{docId} {
      allow read:  if isAnyStaff();
      allow write: if isAdmin() || isTech();
    }

    // ── appdata: main + signatures ──────────────────────────────
    match /appdata/{doc} {
      allow read:  if isAnyStaff();
      // เฉพาะ admin เขียน main/signatures ได้
      allow write: if isAdmin();
    }

    // ── machines ────────────────────────────────────────────────
    match /machines/{docId} {
      allow read:  if isAnyStaff();
      allow create, update: if isAdmin() || isTech();
      allow delete: if isAdmin();
    }

    // ── users: admin เท่านั้น write, user อ่านได้เฉพาะตัวเอง ──
    match /users/{userId} {
      allow read:  if isAdmin() || (isRealUser() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    // ── tickets ─────────────────────────────────────────────────
    match /tickets/{docId} {
      allow read:   if isAnyStaff();
      allow create: if isAnyStaff();
      // ช่างแก้ไขได้เฉพาะ ticket ที่ assigned ให้ตัวเอง หรือ admin
      allow update: if isAdmin()
                    || (isTech() && resource.data.assigneeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── ticket_photos ───────────────────────────────────────────
    match /ticket_photos/{docId} {
      allow read:   if isAnyStaff();
      allow create: if isAnyStaff();
      // ✅ fix #2: tech อัพเดทรูปของตัวเองได้ (techId ถูก save ตอน upload)
      // fallback: ถ้า doc ยังไม่มี techId (reporter สร้างก่อน) → tech ที่ assigned ticket นั้นอัพเดทได้
      allow update: if isAdmin()
                    || (isTech() && (
                         !('techId' in resource.data)
                         || resource.data.techId == request.auth.uid
                       ));
      allow delete: if isAdmin();
    }

    // ── signatures (subcollection per ticket) ───────────────────
    // ✅ fix #1: ย้ายจาก appdata/signatures → subcollection นี้ใน v20
    match /signatures/{tid} {
      allow read:  if isAnyStaff();
      // tech เซ็นได้เฉพาะ ticket ที่ assigned ตัวเอง, reporter เซ็นยืนยันรับงานได้, admin ทำได้ทุกอย่าง
      allow write: if isAdmin()
                   || isTech()
                   || isReporter();
    }

    // ── block everything else ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
