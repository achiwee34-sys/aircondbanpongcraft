rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── appdata: อ่านได้เสมอ (guest), เขียนได้เฉพาะ authenticated (รวม anonymous) ──
    match /appdata/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // block ทุกอย่างที่ไม่ได้ระบุ explicitly
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
