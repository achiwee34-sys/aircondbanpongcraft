rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── aircon_data: custom auth (ไม่ใช้ Firebase Auth) ──
    // อนุญาต read/write ทั้งหมดเพราะระบบใช้ custom login + session ใน localStorage
    match /aircon_data/{docId} {
      allow read, write: if true;
    }

    // ── appdata: public read (สำหรับ config/version check) ──
    match /appdata/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // ── machines: อ่านได้ทุกคน, เขียนได้ (custom auth ควบคุมผ่าน app logic) ──
    match /machines/{docId} {
      allow read, write: if true;
    }

    // ── users collection (ถ้ามีแยก): ──
    match /users/{userId} {
      allow read, write: if true;
    }

    // ── tickets, pm, history ──
    match /tickets/{docId} {
      allow read, write: if true;
    }

    // ── block everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
