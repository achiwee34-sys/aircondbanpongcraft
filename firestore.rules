rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── appdata: อ่านได้เสมอ (guest/public), เขียนได้เฉพาะ authenticated (รวม anonymous) ──
    // App ใช้ firebase.auth().signInAnonymously() ทุก session
    // custom login ของแอปไม่ใช้ Firebase Auth → ใช้ anonymous auth เพื่อ authorize write
    match /appdata/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── block ทุกอย่างที่ไม่ได้ระบุ explicitly ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
