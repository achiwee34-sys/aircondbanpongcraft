rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helper: ตรวจสอบ app secret หรือ Firebase Auth ──
    // ระบบใช้ custom auth — ต้องผ่าน Firebase Auth anonymous หรือส่ง appSecret ใน request
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── aircon_data: ต้อง authenticated เท่านั้น ──
    match /aircon_data/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── appdata: อ่านได้ถ้า authenticated, เขียนได้ถ้า authenticated ──
    match /appdata/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── machines: ต้อง authenticated ──
    match /machines/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── users collection: ต้อง authenticated ──
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // ── tickets, pm, history: ต้อง authenticated ──
    match /tickets/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── ticket_photos: เก็บรูปแยก document ──
    match /ticket_photos/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── block everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
